# ── Git repo containing your skills ──
SKILLS_REPO_URL=https://github.com/Greg-Klein/ai-rules-skills.git

# ── For private repos ──
# GIT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GIT_USERNAME=oauth2          # Required for GitLab (PAT). Omit for GitHub.

# ── Optional ──
SKILLS_REPO_BRANCH=master
SKILLS_SUBDIR=skills
SYNC_INTERVAL_SEC=300
CLONE_DIR=/data/skills-repo
PORT=3000
